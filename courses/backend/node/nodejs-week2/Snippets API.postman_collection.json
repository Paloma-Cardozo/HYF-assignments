  "item": [
    {
      "name": "Get All Snippets",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "  pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has data array\", function () {\r",
              "  const json = pm.response.json();\r",
              "  pm.expect(json).to.have.property(\"data\");\r",
              "  pm.expect(json.data).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"First snippet has required fields\", function () {\r",
              "  const json = pm.response.json();\r",
              "  if (json.length > 0) {\r",
              "    const snippet = json[0];\r",
              "    pm.expect(snippet).to.have.property(\"id\");\r",
              "    pm.expect(snippet).to.have.property(\"title\");\r",
              "    pm.expect(snippet).to.have.property(\"contents\");\r",
              "    pm.expect(snippet).to.have.property(\"user\");\r",
              "  }\r",
              "});\r",
              "\r",
              "pm.test(\"Snippet has numeric 'id'\", function () {\r",
              "  const json = pm.response.json();\r",
              "  if (json.length > 0) {\r",
              "    pm.expect(json[0].id).to.be.a(\"number\");\r",
              "  }\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
